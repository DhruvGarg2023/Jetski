{
  "name": "ai-code-reviewer-backend",
  "version": "1.0.0",
  "description": "Real-Time AI Code Reviewer Backend",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "start": "node src/cluster.js",
    "dev": "nodemon src/server.js",
    "lint": "eslint src/**/*.js",
    "lint:fix": "eslint src/**/*.js --fix",
    "format": "prettier --write \"src/**/*.js\"",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:migrate:prod": "node scripts/migrate.js",
    "db:seed": "prisma db seed",
    "db:studio": "prisma studio",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f backend",
    "test": "vitest run",
    "test:watch": "vitest",
    "evals": "node evals/run_evals.js"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@prisma/client": "^5.22.0",
    "axios": "^1.18.1",
    "bcryptjs": "^3.0.3",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "express-rate-limit": "^8.5.2",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.3",
    "lru-cache": "^11.5.1",
    "morgan": "^1.10.0",
    "pg-boss": "^12.24.1",
    "pino": "^8.19.0",
    "pino-pretty": "^13.1.3",
    "pino-roll": "^4.0.0",
    "socket.io": "^4.8.3",
    "swagger-ui-express": "^5.0.1",
    "yaml": "^2.9.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "nodemon": "^3.1.0",
    "prettier": "^3.2.5",
    "prisma": "^5.22.0",
    "supertest": "^7.2.2",
    "vitest": "^4.1.9"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  }
}
